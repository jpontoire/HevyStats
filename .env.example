# HevyStats is "Bring Your Own Key": in production, users paste their own
# Anthropic API key in the app UI and it is kept in the browser only
# (localStorage / IndexedDB), never sent anywhere but https://api.anthropic.com.
#
# This variable is optional and only useful for local development, e.g. to
# pre-fill the key while testing the chatbot without pasting it every reload.
VITE_ANTHROPIC_API_KEY=
